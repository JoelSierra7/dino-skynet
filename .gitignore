# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Keep data folder structure, but ignore actual data files
data/**
!data/
!data/**/
!data/**/.gitkeep
!data/README.txt

# Keep outputs folder structure, but ignore generated output files
outputs/**
!outputs/
!outputs/**/
!outputs/**/.gitkeep

analysis/outputs/**
!analysis/outputs/
!analysis/outputs/**/
!analysis/outputs/**/.gitkeep

# Keep models folder structure, but ignore actual model artifacts
models/**
!models/
!models/**/
!models/**/.gitkeep

# Large/model artifacts
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.h5

# Environment/secrets
.env
.env.*
!.env.example

# VS Code / IDEs
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db